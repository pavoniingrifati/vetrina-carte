    const rows = [1,2,3].map(i=>{
      const s=saved[i]; const title=s ? `${FORMATIONS[s.formation]?.label || s.formation} · ${Object.keys(s.squad||{}).length}/11` : 'Slot vuoto';
      const when=s && s.savedAt ? new Date(s.savedAt).toLocaleString('it-IT') : '—';
      return `<div class="mode-row"><div><b>Rosa ${i}</b><p class="mini-note">${esc(title)} · ${esc(when)}</p></div><button class="mode-btn primary" data-save-slot="${i}">Salva</button><button class="mode-btn" data-load-slot="${i}" ${s?'':'disabled'}>Carica</button></div>`;
    }).join('');
    $('#cardStrip').innerHTML = `<div class="mode-grid"><div class="mode-card" style="grid-column:1/-1"><h4>Squad Selector</h4>${rows}<p class="mini-note">Il pulsante “Salva rosa” in alto salva la rosa rapida; qui puoi gestire più slot.</p></div></div>`;
    $$('[data-save-slot]').forEach(b=>b.addEventListener('click',()=>{const all=readStored(SQUAD_LIST_KEY,{}); all[b.dataset.saveSlot]=squadPayload(); writeStored(SQUAD_LIST_KEY,all); toast('Rosa salvata nello slot '+b.dataset.saveSlot); renderSelectorPanel();}));
    $$('[data-load-slot]').forEach(b=>b.addEventListener('click',()=>{const all=readStored(SQUAD_LIST_KEY,{}); if(applySquadPayload(all[b.dataset.loadSlot])){renderPitch(); renderActivePanel(); renderPreview(); toast('Rosa caricata');}}));
  }
  function renderKitPanel(){
    $('#deckRole').textContent='NUMBERS';
    $('#deckHelp').textContent='Assegna numeri di maglia ai giocatori già inseriti in campo.';
    const rows = currentSlots().map(([id,role])=>{
      const c=squad[id];
      if(!c) return `<div class="kit-row"><span>${esc(role)} · slot vuoto</span><span>—</span><button class="mode-btn" data-select-slot="${esc(id)}">Scegli</button></div>`;
      const key=c.id; const val=kitNumbers[key] || '';
      return `<div class="kit-row"><span>${esc(role)} · <b>${esc(c.name)}</b></span><input type="number" min="1" max="99" value="${esc(val)}" data-kit="${esc(key)}" placeholder="N°"><button class="mode-btn" data-select-slot="${esc(id)}">Vedi</button></div>`;
    }).join('');
    $('#cardStrip').innerHTML = `<div class="mode-grid"><div class="mode-card" style="grid-column:1/-1"><h4>Kit Numbers</h4>${rows || '<p>Nessun giocatore inserito.</p>'}</div></div>`;
    $$('[data-kit]').forEach(inp=>inp.addEventListener('input',()=>{const parsed=parseInt(inp.value,10); if(Number.isFinite(parsed)){kitNumbers[inp.dataset.kit]=Math.max(1,Math.min(99,parsed)); inp.value=kitNumbers[inp.dataset.kit];} else delete kitNumbers[inp.dataset.kit]; writeStored(KIT_KEY, kitNumbers); toast('Numero aggiornato');}));
    $$('[data-select-slot]').forEach(b=>b.addEventListener('click',()=>{activeSlotId=b.dataset.selectSlot; renderPitch(); renderKitPanel(); renderPreview();}));
  }
  function renderStatsPanel(){
    $('#deckRole').textContent='STATS';
    $('#deckHelp').textContent='Statistiche e dettagli della carta selezionata.';
    const slot=currentSlot(), card=selectedCard();
    if(!slot){$('#cardStrip').innerHTML='<div class="mode-grid"><div class="mode-card"><h4>Player Stats</h4><p>Seleziona uno slot o una carta in campo per vedere le statistiche.</p></div></div>'; return;}
    if(!card){$('#cardStrip').innerHTML=`<div class="mode-grid"><div class="mode-card"><h4>Slot ${esc(slot[1])}</h4><p>Ancora vuoto. Vai su Squad Builder per scegliere una carta compatibile.</p><button class="mode-btn primary" id="goBuilder" type="button">Apri Squad Builder</button></div></div>`; $('#goBuilder').addEventListener('click',()=>setMode('builder')); return;}
    const ovr = knownOvr(card) || '…';
    $('#cardStrip').innerHTML = `<div class="mode-grid">
      <div class="mode-card"><h4>${esc(card.name)}</h4><div class="stat-big" id="panelOvr">${esc(ovr)}</div><p>OVR letto con OCR dalla grafica carta: controllo angolo alto sinistro, angolo alto destro e fascia alta.</p><button class="mode-btn" id="scanOvrBtn" type="button">Rileggi OVR</button><div style="display:grid;grid-template-columns:1fr auto;gap:8px;margin-top:8px"><input id="manualOvrInput" type="number" min="40" max="99" placeholder="Correggi OVR"><button class="mode-btn primary" id="manualOvrBtn" type="button">OK</button></div></div>
      <div class="mode-card"><h4>Dettagli</h4><div class="stat-kv"><span>Ruolo</span><b>${esc(card.role)}</b><span>Rarità</span><b>${esc(card.rarity || '—')}</b><span>Serie</span><b>${esc(card.series || '—')}</b><span>Game</span><b>${esc(card.game || '—')}</b></div></div>
      <div class="mode-card"><h4>Testo carta</h4><p>${esc(card.text || 'Nessun testo disponibile.')}</p><p class="mini-note">${esc((card.tags||[]).join(' · '))}</p></div>
    </div>`;
    const updatePanelOvr=n=>{const el=$('#panelOvr'); if(el) el.textContent=n || 'N/D'; updateOvrDisplay();};
    if(!knownOvr(card)) readOvrFromImage(card).then(updatePanelOvr);
    $('#scanOvrBtn').addEventListener('click',()=>{delete ovrCache[card.id]; delete ovrCache[card.uid]; delete card.ovr; writeStored(OVR_CACHE_KEY,ovrCache); $('#panelOvr').textContent='…'; $('#ovrValue').textContent='…'; toast('Scansiono numero in alto sulla carta'); readOvrFromImage(card).then(updatePanelOvr);});
    $('#manualOvrBtn').addEventListener('click',()=>{const v=parseInt($('#manualOvrInput').value,10); if(!Number.isFinite(v)||v<40||v>99){toast('Inserisci un OVR tra 40 e 99'); return;} card.ovr=v; if(card.id) ovrCache[card.id]=v; if(card.uid) ovrCache[card.uid]=v; writeStored(OVR_CACHE_KEY,ovrCache); updatePanelOvr(v); toast('OVR salvato');});
  }
  function updateStats(){
    const slots = currentSlots(); let filled=0, correct=0; const series={};
    slots.forEach(s=>{ const c=squad[s[0]]; if(c){filled++; if(roleOk(c,s[1])) correct++; if(c.series) series[c.series]=(series[c.series]||0)+1; }});
    const top = Object.entries(series).sort((a,b)=>b[1]-a[1])[0];
    $('#filledCount').textContent = filled + '/11'; $('#correctRoles').textContent = correct + '/11'; $('#topSeries').textContent = top ? top[0] + ' (' + top[1] + ')' : '—';
    updateOvrDisplay();
  }
  function saveSquad(){
    localStorage.setItem(STORAGE_KEY, JSON.stringify(squadPayload()));
    toast('Rosa salvata');
  }
  function loadSaved(){
    try{ const data=JSON.parse(localStorage.getItem(STORAGE_KEY)||'null'); if(!data) return; applySquadPayload(data); }catch(e){}
  }
  function resetSquad(){squad={}; activeSlotId=null; renderPitch(); renderActivePanel(); renderPreview(); toast('Rosa svuotata');}
  function autoFill(){
    squad={}; activeSlotId=null; const used=new Set();
    currentSlots().forEach(([id,role])=>{ const pick=players.find(c=>!used.has(c.uid) && roleOk(c,role)); if(pick){squad[id]=pick; used.add(pick.uid);} });
    renderPitch(); renderActivePanel(); renderPreview(); updateStats(); toast('Rosa auto-completata');
  }
  function changeFormation(value){
    const old = squad; currentFormation = value; squad = {};
    currentSlots().forEach(([id,role])=>{ if(old[id] && roleOk(old[id],role)) squad[id]=old[id]; });
    activeSlotId=null; renderPitch(); renderActivePanel(); renderPreview();
  }
  async function init(){
    allCards = normalizeCards(await loadCards());
    players = allCards.filter(c=>PLAYER_ROLES.has(c.role));
    players.sort((a,b)=>(RARITY_RANK[b.rarity]||0)-(RARITY_RANK[a.rarity]||0) || a.role.localeCompare(b.role) || a.name.localeCompare(b.name));
    $('#cardsCount').textContent = allCards.length; $('#playersCount').textContent = players.length;
    populateFilters(); loadSaved(); markMenu(); renderPitch(); renderActivePanel(); renderPreview();
    $('#formationSelect').addEventListener('change', e=>changeFormation(e.target.value));
    $('#formationText').addEventListener('click', e=>{ if(e.target && e.target.id==='formationSelect') return; const fs=$('#formationSelect'); if(fs && fs.showPicker) fs.showPicker(); else if(fs) fs.focus(); });
    $$('.menu-action').forEach(li=>li.addEventListener('click', ()=>setMode(li.dataset.mode)));
    ['searchInput','roleFilter','gameFilter','rarityFilter'].forEach(id=>$('#'+id).addEventListener('input', ()=>{ if(id==='roleFilter' && currentSlot()) activeSlotId=null; deckLimit = 220; currentMode='builder'; markMenu(); renderDeck(); renderPreview(); }));
    $('#saveBtn').addEventListener('click', saveSquad); $('#resetBtn').addEventListener('click', resetSquad); $('#autoBtn').addEventListener('click', autoFill); $('#moreBtn').addEventListener('click', ()=>{ currentMode='builder'; markMenu(); deckLimit += 220; renderDeck(); });
  }
  init();
})();
</script>
</body>
</html>
