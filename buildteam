        {name:'alto dx', x:.64, y:.015, w:.36, h:.245},
        {name:'fascia alta', x:.00, y:.00, w:1, h:.245}
      ];
      const variants = ['darkText','lightText','raw'];
      let all=[];
      for(const region of regions){
        for(const variant of variants){
          try{
            const canvas = makeOvrCanvas(img, region, variant);
            const found = await ocrCanvas(canvas, Tesseract);
            all = all.concat(found);
