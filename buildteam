<!doctype html>
<html lang="it">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>FUTTU - Squad Builder</title>
<meta name="description" content="Crea la rosa dei tuoi sogni con tutte le carte disponibili, rispettando i ruoli dei giocatori.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --hud:#0b0d12;
  --hud2:#151820;
  --line:rgba(255,255,255,.18);
  --line2:rgba(255,255,255,.09);
  --text:#f3f6fa;
  --muted:#aab2be;
  --soft:#d7dde7;
  --accent:#eef5dc;
  --gold:#dac277;
  --green:#66ff8e;
  --orange:#ffbd54;
  --red:#ff4c64;
  --blue:#79d7ff;
  --shadow:0 24px 80px rgba(0,0,0,.62);
}
*{box-sizing:border-box}
html,body{margin:0;min-height:100%}
body{
  font-family:Rajdhani,Impact,"Arial Narrow",system-ui,sans-serif;
  color:var(--text);
  background:
    radial-gradient(ellipse at 50% 6%, rgba(184,209,244,.14), transparent 42%),
    linear-gradient(180deg,rgba(7,10,17,.4),rgba(4,6,11,.85) 48%,#030408),
    #05070c;
  overflow:hidden;
  letter-spacing:.015em;
}
body::before{
  content:"";
  position:fixed;inset:-6vh -6vw;z-index:0;pointer-events:none;
  background:
    radial-gradient(ellipse at 50% 2%, rgba(180,202,238,.18), transparent 24%),
    repeating-linear-gradient(105deg, rgba(255,255,255,.045) 0 1px, transparent 1px 12px),
    linear-gradient(100deg, transparent 0 7%, rgba(16,20,31,.92) 7% 16%, transparent 16% 84%, rgba(16,20,31,.92) 84% 93%, transparent 93% 100%);
  filter:blur(.2px);
  opacity:.75;
}
body::after{
  content:"";
  position:fixed;inset:0;z-index:0;pointer-events:none;
  background:radial-gradient(ellipse at center, transparent 34%, rgba(0,0,0,.48) 88%);
}
button,input,select{font:inherit}
button{cursor:pointer;color:inherit}
a{color:inherit;text-decoration:none}
.console{
  position:relative;z-index:1;height:100vh;
  display:grid;
  grid-template-columns:256px minmax(760px,1fr) 272px;
  grid-template-rows:minmax(0,1fr) 224px;
  gap:0;
}
.left-hud,.right-hud{
  min-width:0;
  background:linear-gradient(90deg,rgba(4,6,11,.92),rgba(8,11,17,.62) 72%,rgba(8,11,17,0));
  padding:22px 20px 18px;
  backdrop-filter:blur(2px);
}
.right-hud{
  background:linear-gradient(270deg,rgba(4,6,11,.92),rgba(8,11,17,.62) 72%,rgba(8,11,17,0));
  padding-left:28px;
}
.club-card{display:flex;gap:13px;align-items:center;margin:4px 0 22px}
.crest{
  width:54px;height:62px;display:grid;place-items:center;
  background:linear-gradient(145deg,#f2f2e2,#b74134 44%,#722521);
  clip-path:polygon(50% 0,92% 16%,84% 78%,50% 100%,16% 78%,8% 16%);
  box-shadow:0 0 0 2px rgba(255,255,255,.18),0 16px 30px rgba(0,0,0,.4);
  font-weight:700;color:white;font-size:20px;text-shadow:0 1px 3px #000;
}
.club-name{font-size:25px;font-weight:700;line-height:.9}
.rating{margin-top:8px;color:#f7e28b;font-size:18px;letter-spacing:1px;text-shadow:0 2px 5px #000}
.tiny{font-size:13px;color:var(--soft);font-weight:700;text-transform:uppercase;letter-spacing:.055em}
.menu-title{display:flex;align-items:center;gap:8px;margin:22px 0 8px;color:#d8dee8;font-size:16px;font-weight:700}
.menu-title::before{content:"";width:22px;height:12px;background:linear-gradient(180deg,#e8e8e8 0 3px,transparent 3px),linear-gradient(90deg,transparent 8px,#e8e8e8 8px 14px,transparent 14px);opacity:.8}
.action-list{list-style:none;margin:0 0 18px;padding:0;display:grid;gap:0}
.action-list li,.action-row{
  min-height:34px;display:flex;align-items:center;padding:0 12px;
  color:#ebedf2;font-size:17px;font-weight:600;
  border-left:3px solid transparent;
  text-shadow:0 2px 8px #000;
  cursor:pointer;
}
.action-list li:hover,.action-row:hover{background:rgba(255,255,255,.10)}
.formation-li{height:auto;align-items:stretch!important;display:grid!important;gap:7px;padding:8px 10px!important}
.formation-li .formation-head{display:flex;align-items:center;justify-content:space-between;gap:8px;width:100%;line-height:1}
.formation-li.active{background:rgba(255,255,255,.14);border-left-color:#d9dbdf}.formation-mini{width:100%;height:34px;border:1px solid rgba(255,255,255,.26);background:rgba(4,6,10,.86);color:#f2f5f9;padding:0 8px;font-size:17px;font-weight:700;outline:none;text-transform:uppercase}
.formation-mini:focus{border-color:rgba(238,245,220,.75);box-shadow:0 0 0 2px rgba(238,245,220,.18)}
.action-list li.active:not(.formation-li),.action-row.active{
  color:#0d0f12;background:rgba(255,255,255,.94);text-shadow:none;border-left-color:#d9dbdf;
}
.action-row select{width:100%;height:34px;border:1px solid rgba(255,255,255,.26);background:rgba(4,6,10,.86);color:#f2f5f9}
.hud-block{margin-top:20px;border-top:1px solid var(--line2);padding-top:16px;display:grid;gap:10px}
.hud-btn{
  height:38px;border:1px solid rgba(255,255,255,.18);background:linear-gradient(180deg,rgba(255,255,255,.10),rgba(255,255,255,.04));
  color:#f2f5f9;font-weight:700;font-size:16px;text-transform:uppercase;letter-spacing:.04em;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.12),0 8px 20px rgba(0,0,0,.35);
}
.hud-btn:hover{border-color:rgba(238,245,220,.58);filter:brightness(1.12)}
.hud-btn.primary{background:linear-gradient(180deg,#f4f5ee,#bfc4ba);color:#11151a;text-shadow:none}
.pitch-stage{
  position:relative;min-width:0;padding:28px 10px 8px;
  display:flex;align-items:center;justify-content:center;
  background:
    radial-gradient(ellipse at 50% 0%, rgba(255,255,255,.12), transparent 32%),
    linear-gradient(180deg,rgba(10,18,19,.22),rgba(0,0,0,0));
}
.pitch-frame{
  position:relative;width:min(100%,1500px);height:100%;min-height:720px;max-height:960px;
  filter:drop-shadow(0 28px 50px rgba(0,0,0,.6));
}
.pitch{
  position:absolute;inset:0;border-radius:10px;overflow:hidden;
  background:
    radial-gradient(ellipse at 50% 40%, rgba(255,255,255,.06), transparent 30%),
    linear-gradient(90deg,rgba(255,255,255,.05),transparent 10%,transparent 90%,rgba(255,255,255,.05)),
    repeating-linear-gradient(90deg, rgba(32,93,56,.88) 0 10%, rgba(24,75,47,.88) 10% 20%),
    linear-gradient(180deg,#194b32,#0c2c22 78%,#081d18);
  box-shadow:inset 0 0 120px rgba(0,0,0,.56), inset 0 0 0 2px rgba(255,255,255,.10);
}
.pitch::before{
  content:"";position:absolute;inset:22px 34px;border:2px solid rgba(205,230,228,.16);border-radius:2px;
}
.pitch::after{
  content:"";position:absolute;left:50%;top:50%;width:180px;height:180px;border:2px solid rgba(205,230,228,.14);border-radius:50%;transform:translate(-50%,-50%);
}
.pitch-lines .half{position:absolute;left:34px;right:34px;top:50%;height:2px;background:rgba(205,230,228,.13)}
.pitch-lines .box{position:absolute;left:31%;right:31%;height:112px;border:2px solid rgba(205,230,228,.13)}
.pitch-lines .box.top{top:22px;border-top:0}.pitch-lines .box.bottom{bottom:22px;border-bottom:0}
.pitch-lines .six{position:absolute;left:41%;right:41%;height:48px;border:2px solid rgba(205,230,228,.12)}
.pitch-lines .six.top{top:22px;border-top:0}.pitch-lines .six.bottom{bottom:22px;border-bottom:0}
.formation-mark{
  position:absolute;left:28px;bottom:26px;font-size:64px;font-weight:700;color:rgba(255,255,255,.38);letter-spacing:-.06em;
  text-shadow:0 7px 22px rgba(0,0,0,.75);z-index:1;
}
.pitch-brand{
  position:absolute;left:50%;top:51%;transform:translate(-50%,-50%) rotate(-10deg);font-size:86px;line-height:.8;font-weight:700;
  color:rgba(255,255,255,.06);text-align:center;letter-spacing:-.06em;z-index:0;pointer-events:none;
}
.pitch-brand span{display:block;font-size:20px;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.05)}
.slot{
  --x:50%;--y:50%;position:absolute;left:var(--x);top:var(--y);transform:translate(-50%,-50%);
  width:122px;text-align:center;z-index:5;user-select:none;
}
.slot-card{
  position:relative;margin:0 auto;width:118px;height:164px;display:grid;place-items:center;
  background:linear-gradient(160deg,rgba(92,96,104,.92),rgba(35,38,45,.94) 52%,rgba(19,22,28,.98));
  clip-path:polygon(22% 0,78% 0,100% 22%,100% 78%,78% 100%,22% 100%,0 78%,0 22%);
  box-shadow:0 18px 30px rgba(0,0,0,.54), inset 0 0 0 2px rgba(255,255,255,.09);
  transition:transform .16s ease,filter .16s ease,box-shadow .16s ease;
  overflow:hidden;
}
.slot-card::before{content:"";position:absolute;inset:8px;border:1px solid rgba(255,255,255,.08);clip-path:inherit;pointer-events:none}
.slot:hover .slot-card{transform:translateY(-5px);filter:brightness(1.15);box-shadow:0 24px 34px rgba(0,0,0,.58),0 0 20px rgba(238,245,220,.16)}
.slot.active .slot-card{box-shadow:0 24px 34px rgba(0,0,0,.62),0 0 0 3px rgba(238,245,220,.74),0 0 34px rgba(238,245,220,.22)}
.slot.filled .slot-card{clip-path:polygon(10% 0,90% 0,100% 10%,100% 100%,0 100%,0 10%);background:#171b21;box-shadow:0 20px 32px rgba(0,0,0,.62)}
.slot-card img{width:100%;height:100%;object-fit:cover;display:block}
.ut-mark{position:relative;font-size:34px;font-weight:700;color:rgba(255,255,255,.44);font-style:italic;letter-spacing:-.08em}
.empty-role{position:absolute;bottom:22px;font-size:20px;font-weight:700;color:rgba(255,255,255,.45)}
.slot-name{
  margin:7px auto 0;max-width:132px;padding:4px 7px;background:rgba(4,6,10,.78);border:1px solid rgba(255,255,255,.12);
  color:#e6edf2;font-size:13px;font-weight:700;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
  box-shadow:0 8px 18px rgba(0,0,0,.3);
}
.slot-role{color:#f2e7a4}
.slot-clear{
  position:absolute;right:-8px;top:-8px;z-index:8;width:25px;height:25px;border:0;border-radius:50%;display:none;
  background:rgba(255,76,100,.96);font-weight:700;color:white;box-shadow:0 8px 16px rgba(0,0,0,.5);
}
.slot.filled .slot-clear{display:block}.slot-clear:hover{transform:scale(1.08)}
.right-card{margin-top:40px;display:grid;justify-items:end;gap:16px}
.preview-card{width:92px;height:128px;border-radius:9px;background:linear-gradient(160deg,#2e333d,#101319);display:grid;place-items:center;overflow:hidden;box-shadow:0 18px 32px rgba(0,0,0,.5);clip-path:polygon(10% 0,90% 0,100% 10%,100% 100%,0 100%,0 10%)}
.preview-card img{width:100%;height:100%;object-fit:cover}.preview-card.empty{clip-path:polygon(22% 0,78% 0,100% 22%,100% 78%,78% 100%,22% 100%,0 78%,0 22%);font-weight:700;color:rgba(255,255,255,.45);font-size:26px}
.player-name{font-size:26px;font-weight:700;text-align:right;line-height:.95;max-width:240px}.player-sub{color:var(--muted);font-size:15px;font-weight:700;text-align:right;text-transform:uppercase}.stat-table{width:100%;margin-top:18px;display:grid;gap:9px}.stat-line{display:grid;grid-template-columns:1fr 62px;align-items:center;gap:8px;color:#d9dfe8;font-size:18px;font-weight:700;text-transform:uppercase}.stat-line b{text-align:right;font-size:22px;color:#f3f6fa}.side-counts{margin-top:32px;display:grid;gap:10px}.side-chip{border-top:1px solid var(--line2);padding-top:11px}.side-chip span{display:block;color:var(--muted);font-size:13px;text-transform:uppercase;font-weight:700}.side-chip b{font-size:24px}
.bottom-deck{
  grid-column:1 / -1;grid-row:2;background:linear-gradient(180deg,rgba(15,17,22,.22),rgba(9,11,15,.94) 20%,rgba(6,8,11,.98));
  border-top:1px solid rgba(255,255,255,.13);box-shadow:0 -18px 46px rgba(0,0,0,.58);padding:12px 16px 14px;display:grid;grid-template-columns:220px 1fr;gap:14px;min-width:0;
}
.deck-left{display:grid;align-content:start;gap:8px;border-right:1px solid rgba(255,255,255,.11);padding-right:14px}.deck-label{font-size:16px;text-transform:uppercase;color:#cbd2db;font-weight:700}.deck-role{font-size:44px;line-height:.82;color:#f4f5ee;font-weight:700;letter-spacing:-.05em}.deck-help{color:#aab2be;font-size:14px;font-weight:600;line-height:1.15}.deck-controls{display:grid;grid-template-columns:2fr 1fr 1fr 1fr 130px 118px;gap:8px;margin-bottom:10px}
.deck-controls input,.deck-controls select{
  height:36px;border:1px solid rgba(255,255,255,.17);background:rgba(5,7,12,.82);color:#eff3f9;padding:0 10px;font-weight:700;font-size:15px;outline:0;border-radius:0;
}
.deck-controls input:focus,.deck-controls select:focus{border-color:rgba(238,245,220,.6)}
.count-pill,.more-btn{height:36px;display:grid;place-items:center;border:1px solid rgba(255,255,255,.17);background:rgba(255,255,255,.06);font-weight:700;color:#f4f5ee;font-size:15px;text-transform:uppercase}.more-btn:hover{border-color:rgba(238,245,220,.65);filter:brightness(1.12)}.more-btn[disabled]{opacity:.42;cursor:default;filter:none}
.card-strip{min-width:0;overflow:auto hidden;display:flex;gap:10px;padding-bottom:8px;scrollbar-color:rgba(255,255,255,.28) rgba(255,255,255,.06)}
.bench-card{flex:0 0 92px;position:relative;border:1px solid rgba(255,255,255,.12);background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,.025));padding:4px;min-height:166px;transition:transform .15s ease,filter .15s ease,border-color .15s ease;box-shadow:0 12px 22px rgba(0,0,0,.32)}
.bench-card:hover{transform:translateY(-5px);border-color:rgba(238,245,220,.72);filter:brightness(1.12)}
.bench-card.used{opacity:.46}.bench-card.incompatible{opacity:.34;filter:grayscale(.8)}
.bench-img{width:100%;height:124px;background:#10151d;display:grid;place-items:center;overflow:hidden}.bench-img img{width:100%;height:100%;object-fit:cover}.fallback{padding:6px;text-align:center;font-size:12px;font-weight:700;color:#dce3ec}.bench-meta{padding:5px 2px 1px}.bench-name{font-size:12px;font-weight:700;line-height:.98;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.bench-sub{margin-top:3px;font-size:11px;color:#b8c0cc;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.role-badge{position:absolute;right:5px;top:5px;background:rgba(4,6,10,.82);border:1px solid rgba(255,255,255,.22);padding:2px 5px;font-size:12px;font-weight:700;color:#f1e5a3}.mode-panel{min-height:166px;overflow:auto;padding:12px 10px 8px;border:1px solid rgba(255,255,255,.10);background:linear-gradient(180deg,rgba(255,255,255,.055),rgba(255,255,255,.018));box-shadow:inset 0 1px 0 rgba(255,255,255,.06)}.mode-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:10px}.mode-card{border:1px solid rgba(255,255,255,.12);background:rgba(5,8,13,.64);padding:12px;min-height:86px}.mode-card h4{margin:0 0 8px;font-size:18px;text-transform:uppercase;letter-spacing:.04em}.mode-card p{margin:0;color:#bdc5cf;font-size:14px;font-weight:600;line-height:1.2}.mode-card input,.mode-card select{width:100%;height:34px;background:#05080d;border:1px solid rgba(255,255,255,.20);color:#f3f6fa;padding:0 8px;font-weight:700}.mode-btn{height:34px;border:1px solid rgba(255,255,255,.20);background:rgba(255,255,255,.08);color:#f4f6f8;font-weight:700;text-transform:uppercase}.mode-btn:hover{border-color:rgba(238,245,220,.72)}.mode-btn.primary{background:rgba(238,245,220,.92);color:#101319}.mode-row{display:grid;grid-template-columns:1fr auto auto;gap:8px;align-items:center;border-bottom:1px solid rgba(255,255,255,.08);padding:8px 0}.mode-row:last-child{border-bottom:0}.kit-row{display:grid;grid-template-columns:minmax(140px,1fr) 72px 120px;gap:8px;align-items:center}.kit-row input{height:32px;text-align:center}.stat-big{font-size:48px;line-height:.8;color:#f2e7a4;font-weight:700}.stat-kv{display:grid;grid-template-columns:110px 1fr;gap:6px;font-size:15px;text-transform:uppercase}.stat-kv span{color:#aab2be}.mini-note{color:#abb3bd;font-size:13px;font-weight:700;margin-top:8px;line-height:1.2}.toast{position:fixed;left:50%;bottom:238px;z-index:30;transform:translateX(-50%) translateY(16px);opacity:0;padding:12px 18px;background:rgba(8,10,14,.96);border:1px solid rgba(238,245,220,.48);box-shadow:0 18px 38px rgba(0,0,0,.55);font-size:17px;font-weight:700;text-transform:uppercase;transition:.22s ease}.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
@media(max-width:1240px){
  body{overflow:auto}.console{height:auto;min-height:100vh;grid-template-columns:210px minmax(620px,1fr);grid-template-rows:minmax(760px,1fr) auto auto}.right-hud{grid-column:1/-1;grid-row:2;background:rgba(5,7,12,.94);display:grid;grid-template-columns:1fr 2fr;padding:14px 18px}.bottom-deck{grid-row:3}.pitch-stage{min-height:760px}.deck-controls{grid-template-columns:1fr 1fr 1fr}.count-pill{grid-column:1/-1}.slot{width:104px}.slot-card{width:100px;height:139px}.formation-mark{font-size:48px}.pitch-brand{font-size:60px}}
@media(max-width:820px){
  .console{display:block}.left-hud,.right-hud{background:rgba(5,7,12,.94);padding:14px 16px}.action-list{grid-template-columns:1fr 1fr}.pitch-stage{height:680px;padding:10px}.pitch-frame{min-height:640px}.slot{width:76px}.slot-card{width:72px;height:100px}.slot-name{font-size:10px;max-width:90px}.ut-mark{font-size:24px}.empty-role{font-size:14px;bottom:14px}.bottom-deck{display:block}.deck-left{border-right:0;border-bottom:1px solid rgba(255,255,255,.11);padding:0 0 10px;margin-bottom:10px}.deck-role{font-size:32px}.deck-controls{grid-template-columns:1fr}.bench-card{flex-basis:84px}.bench-img{height:112px}.right-card{justify-items:start}.player-name,.player-sub{text-align:left}.toast{bottom:18px}}
</style>
</head>
<body>
<div class="console">
  <aside class="left-hud">
    <a class="club-card" href="./FUTTU.html" title="Torna ai pacchetti">
      <div class="crest">XI</div>
      <div>
        <div class="club-name">FUTTU<br>Squad</div>
        <div class="rating">★★★★★</div>
        <div class="tiny">Dream builder</div>
      </div>
    </a>

    <div class="menu-title">Squad Actions</div>
    <ul class="action-list">
      <li class="formation-li active" id="formationText">
        <div class="formation-head"><span>Formation</span><strong id="formationLabelSide">4-4-2</strong></div>
        <select id="formationSelect" class="formation-mini" aria-label="Modulo">
          <option value="442">4-4-2</option>
          <option value="541">5-4-1</option>
          <option value="433">4-3-3</option>
          <option value="4231">4-2-3-1</option>
          <option value="4312">4-3-1-2</option>
          <option value="343">3-4-3</option>
          <option value="352">3-5-2</option>
          <option value="451">4-5-1</option>
        </select>
      </li>
      <li class="menu-action" data-mode="tactics">Custom Tactics</li>
      <li class="menu-action active" data-mode="builder">Squad Builder</li>
      <li class="menu-action" data-mode="selector">Squad Selector</li>
      <li class="menu-action" data-mode="numbers">Kit Numbers</li>
      <li class="menu-action" data-mode="stats">Player Stats</li>
    </ul>

    <div class="hud-block">
      <button class="hud-btn primary" id="saveBtn">Salva rosa</button>
      <button class="hud-btn" id="autoBtn">Auto completa</button>
      <button class="hud-btn" id="resetBtn">Reset</button>
      <a class="hud-btn" style="display:grid;place-items:center" href="./my-cards">Le mie carte</a>
    </div>
  </aside>

  <main class="pitch-stage">
    <div class="pitch-frame">
      <div class="pitch" id="pitch">
        <div class="pitch-lines" aria-hidden="true">
          <div class="half"></div>
          <div class="box top"></div><div class="box bottom"></div>
          <div class="six top"></div><div class="six bottom"></div>
        </div>
        <div class="pitch-brand">UT<span>Ultimate Team</span></div>
        <div class="formation-mark" id="formationMark">4-4-2</div>
      </div>
    </div>
  </main>

  <aside class="right-hud">
    <div class="right-card">
      <div class="preview-card empty" id="previewCard">UT</div>
      <div>
        <div class="player-name" id="previewName">Seleziona uno slot</div>
        <div class="player-sub" id="previewSub">poi scegli una carta compatibile</div>
      </div>
      <div class="stat-table" aria-label="Statistiche rosa">
        <div class="stat-line"><span>OVR</span><b id="ovrValue">-</b></div>
        <div class="stat-line"><span>Carte</span><b id="cardsCount">—</b></div>
